    {
      "parameters": {
        "jsCode": "const blocks = $input.all();\nlet allText = '';\n\nfor (const item of blocks) {\n  const content = item.json.content;\n  if (content) {\n    allText += content + '\\n';\n  }\n}\n\nconst urlPattern = /https:\\/\\/ghost-gym-v3-testing\\.up\\.railway\\.app\\/static\\/assets\\/img\\/(tutorials|build-in-public)\\/[^\\s\\n)]+\\.(png|jpg|jpeg)/gi;\nlet urls = (allText.match(urlPattern) || []).slice(0, 4);\n\nif (urls.length === 0) {\n  const imageUrl = $('Query Tutorial Posts1').first().json.properties?.['Image URL']?.url;\n  if (imageUrl) {\n    urls = [imageUrl];\n  }\n}\n\nif (urls.length === 0) {\n  throw new Error('No image URLs found in page content or Image URL property');\n}\n\nreturn urls.map((url, i) => ({\n  json: { url, index: i }\n}));"
      },
