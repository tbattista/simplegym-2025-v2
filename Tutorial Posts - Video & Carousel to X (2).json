      "parameters": {
        "jsCode": "const items = $input.all();\nconst mediaIds = items.map(item => item.json.media_id_string);\n\nconst queryNode = $('Query Tutorial Posts1').first();\nconst caption = queryNode.json.properties?.Caption?.rich_text\n  ?.map(t => t.plain_text).join('') || '';\nconst pageId = queryNode.json.id;\n\nreturn [{\n  json: {\n    mediaIds,\n    caption,\n    pageId\n  }\n}];"
      },
